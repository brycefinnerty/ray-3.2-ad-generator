# Copy this file to `.env` and fill in your own values.
# `.env` is gitignored. Never commit real keys.

# Luma API key (uni-1 images + ray-3.2 video). Sign up here:
#   https://lumalabs.ai/app?utm_source=influencer&utm_medium=linkedin&utm_campaign=mrpaidsocial-ray-3_2&utm_content=faved&from_faved=true
# Then: dashboard → API keys. Format: starts with "luma-api-".
LUMA_API_KEY=

# Meta system user access token — Meta Business Suite → Settings → Users →
# System Users → Generate New Token. Required scopes:
#   business_management, ads_management, pages_show_list,
#   pages_read_engagement, pages_manage_ads, catalog_management, read_insights
ACCESS_TOKEN=

# Meta ad account, prefixed `act_`. Get yours from `meta ads adaccount list`
# after the Meta CLI is set up and authenticated.
AD_ACCOUNT_ID=act_

# ElevenLabs API key — required ONLY for the video film skills (claymation-ad,
# cinematic-ad), which generate VO / SFX / music. Get one at
# https://elevenlabs.io → Profile → API key. Leave blank if you only use the
# image skills or ray3-video-ad (single clips, silent).
ELEVENLABS_API_KEY=
